{
  "name": "postext",
  "version": "0.1.6",
  "description": "A programmable typesetter for the web. Layout engine that applies professional editorial rules — columns, orphan/widow prevention, resource placement, footnotes — to semantic content. Built on @chenglou/pretext for DOM-free text measurement.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://postext.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/drnachio/postext.git",
    "directory": "packages/postext"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@postext/typescript-config": "workspace:*",
    "@types/react": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "react": "^19.2.4",
    "typescript": "latest",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5"
  }
}
