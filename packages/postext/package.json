{
  "name": "postext",
  "version": "0.0.1",
  "description": "A programmable typesetter for the web",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AUsername/postext.git",
    "directory": "packages/postext"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@postext/typescript-config": "workspace:*",
    "@types/react": "^19",
    "react": "^19.2.4",
    "typescript": "latest"
  }
}
