{
  "name": "postext-sandbox",
  "version": "0.1.0",
  "description": "Interactive sandbox UI for experimenting with the Postext layout engine. VS Code-like interface with markdown editor, configuration panel, and live preview.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drnachio/postext.git",
    "directory": "packages/postext-sandbox"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "postext": ">=0.1.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "colorjs.io": "^0.6.1",
    "lucide-react": "^0.513.0",
    "postext-pdf": "workspace:*"
  },
  "devDependencies": {
    "@postext/typescript-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postext": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "latest",
    "typescript-eslint": "^8.61.0"
  }
}
